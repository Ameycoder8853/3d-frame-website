# GEMINI_API_KEY: Required for Gemini AI generation & Firebase Authentication proxy mapping.
# AI Studio automatically manages this. The .env file has been ignored to secure secrets.
GEMINI_API_KEY=

# FIREBASE_API_KEY: Securely stored Firebase Web API Key to prevent repository leak warnings.
FIREBASE_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL="https://example.com"

